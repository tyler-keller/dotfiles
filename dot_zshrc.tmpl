{{ if .isMac -}}
# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi
{{ end -}}

export ZSH="$HOME/.oh-my-zsh"

{{ if .isMac -}}
ZSH_THEME="powerlevel10k/powerlevel10k"
{{ else -}}
ZSH_THEME="philips"
{{ end -}}

plugins=(git zsh-autosuggestions zsh-syntax-highlighting)

source $ZSH/oh-my-zsh.sh

[ -f ~/.dev_env.sh ] && source ~/.dev_env.sh
[ -f ~/.dev_env_personal.sh ] && source ~/.dev_env_personal.sh

alias cl="clear"

export GPG_TTY=$(tty)

{{ if .isLinux -}}
# Tell gpg-agent which TTY to use for pinentry (essential over SSH)
gpg-connect-agent updatestartuptty /bye >/dev/null 2>&1

# Prime gpg-agent passphrase cache if not already cached.
# --pinentry-mode error fails instead of prompting when cache is empty.
if [[ -o interactive ]] && ! echo "" | gpg --batch --pinentry-mode error --clearsign >/dev/null 2>&1; then
	echo "🔐 Priming gpg-agent..."
	echo "test" | gpg --clearsign > /dev/null
fi

alias cc="claude --dangerously-skip-permissions"

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
{{ end -}}

{{ if .isMac -}}
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
{{ end -}}

{{ if .isPersonalMac -}}
[ -f ~/.zsh/et.zsh ] && source ~/.zsh/et.zsh
{{ end -}}

# Git worktree helpers (wt new / wt rm / wt ls / wt cd)
[ -f ~/.zsh/worktree.zsh ] && source ~/.zsh/worktree.zsh
